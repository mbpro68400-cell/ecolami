# EcoLami — Variables d'environnement
# Copier vers .env.local et remplir les valeurs

# ─── Google Gemini ─────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Clerk Auth ────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_FAMILLE_MONTHLY=price_xxx
STRIPE_PRICE_FAMILLE_ANNUAL=price_xxx
STRIPE_PRICE_FAMILLE_PLUS_MONTHLY=price_xxx
STRIPE_PRICE_FAMILLE_PLUS_ANNUAL=price_xxx
STRIPE_PRICE_ECOLE_MONTHLY=price_xxx

# ─── Resend ────────────────────────────────────
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@ecolami.fr

# ─── Voix (optionnel) ──────────────────────────
NEXT_PUBLIC_OPENAI_API_KEY=sk-xxx
NEXT_PUBLIC_ELEVENLABS_API_KEY=xxx

# ─── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your-random-secret-here
